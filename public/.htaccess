# WrightCommerce API - Apache Configuration
# NO CORS headers here - options.php handles OPTIONS

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /wrightcommerce/public/
    
    # ✅ Route OPTIONS requests to options.php (which sets CORS headers)
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule .* options.php [L]
    
    # Allow direct access to existing files/folders
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Route everything else to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Disable directory listing
Options -Indexes

# Protect hidden files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Default charset
AddDefaultCharset UTF-8

# PHP settings
<IfModule mod_php.c>
    php_flag display_errors On
    php_value error_reporting E_ALL
</IfModule>