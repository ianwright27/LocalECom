# WrightCommerce API - Apache Configuration
# Clean URLs and single entry point routing
# CORS is handled in PHP (cors.php), NOT here

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Base path for the project
    RewriteBase /wrightcommerce/public/

    # Allow direct access to existing files and folders
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route all other requests to index.php
    RewriteRule ^ index.php [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "http://localhost:3000"
    Header set Access-Control-Allow-Credentials "true"
    Header set Vary "Origin"
</IfModule>

# Disable directory listing
Options -Indexes

# Protect hidden and sensitive files
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Default character encoding
AddDefaultCharset UTF-8

# PHP settings (development only)
<IfModule mod_php.c>
    php_flag display_errors On
    php_value error_reporting E_ALL
    # ⚠️ Disable in production:
    # php_flag display_errors Off
</IfModule>
